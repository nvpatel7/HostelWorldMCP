# Demo mode: serve embedded fixture responses instead of scraping the live site.
# Useful for local development and tests without any network access.
# Set to false (or unset) to scrape the real Hostelworld backend.
HOSTELWORLD_DEMO=false

# --- Scrape mode (live) settings ---
# The apigee base host that backs Hostelworld's public PWA.
HOSTELWORLD_BASE_URL=https://prod.apigee.hostelworld.com

# A PWA page used to bootstrap the public api-key the site ships to browsers.
# Leave unset to use the built-in default.
# HOSTELWORLD_PWA_PAGE_URL=

# Optional: pin the apigee api-key instead of scraping it from the page. The key
# is the PWA's public browser key, not a partner secret; pin it only to avoid the
# page fetch (e.g. in locked-down environments).
# HOSTELWORLD_APIGEE_KEY=

# Optional: override the browser-like User-Agent used for upstream requests.
# HOSTELWORLD_USER_AGENT=

# Max concurrent in-flight upstream requests (politeness toward the site).
MAX_IN_FLIGHT=4

# --- Circuit breaker (trips when scraping breaks) ---
# Consecutive upstream failures that open the breaker, and how long it stays open
# before a half-open probe. While open, tools fail fast with service_busy.
BREAKER_MAX_FAILURES=5
BREAKER_COOLDOWN_SECS=30

# HTTP listen address for the MCP server.
LISTEN_ADDR=127.0.0.1:8080

# Daily upstream-call budget. When daily count hits SOFT_CAP_PCT * BUDGET we
# only serve cached results; at HARD_CAP_PCT * BUDGET we refuse all calls until
# UTC midnight.
DAILY_BUDGET=10000
SOFT_CAP_PCT=70
HARD_CAP_PCT=95

# Per-IP rate limit: bucket size + refill per second.
RATE_BUCKET=20
RATE_REFILL_PER_SEC=0.2

# Global ceiling on upstream calls per second + burst. Kept conservative because
# we scrape an unofficial backend.
GLOBAL_QPS=2.0
GLOBAL_BURST=5

# Trusted proxy header for real client IP. Set to "CF-Connecting-IP" when
# behind Cloudflare, empty otherwise (falls back to RemoteAddr).
REAL_IP_HEADER=
